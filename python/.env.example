# Repo kök dizinine kopyalayın: cp python/.env.example .env

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=lojistik_db

# true yapılırsa PostgreSQL zorunlu; bağlantı yoksa script durur
REQUIRE_POSTGRES=false

# true yapılırsa merge_and_dedup CSV yazdıktan sonra DB'ye de senkronize eder
SYNC_TO_DB=false

SERPAPI_KEY=
